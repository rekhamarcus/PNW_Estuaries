#so using rast() function on estuaries and then cropping it to a bbox with the exact same extent worked, but not giving us individual estuaries
bboxy <- st_bbox((c(xmin = -133.130120075859, xmax = -121.937071717489, ymin = 38.7578990718796, ymax = 55.9376038918338)), crs = st_crs(4326))
esty_rasty <- rast(estuaries)
cropped_queen <- crop(esty_rasty, bboxy)
plot(cropped_queen)

